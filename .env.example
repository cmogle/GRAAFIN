# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Optional guardrail: fail fast if runtime points at wrong project.
# EXPECTED_SUPABASE_PROJECT_REF=your_project_ref

# Primary athlete scope for analysis UX (defaults to Fionnuala id)
# APP_PRIMARY_ATHLETE_ID=69629233

# In-repo Strava sync credentials (recommended)
# Either define STRAVA_ATHLETES_JSON (array of athlete credentials) OR per-athlete vars below.
# STRAVA_ATHLETES_JSON=[{"slug":"fionnuala","athleteId":69629233,"clientId":"...","clientSecret":"...","refreshToken":"..."}]
# FIONNUALA_STRAVA_ATHLETE_ID=69629233
# FIONNUALA_STRAVA_CLIENT_ID=
# FIONNUALA_STRAVA_CLIENT_SECRET=
# FIONNUALA_STRAVA_REFRESH_TOKEN=
# FIONNUALA_STRAVA_ACCESS_TOKEN=
# CONOR_STRAVA_ATHLETE_ID=9750533
# CONOR_STRAVA_CLIENT_ID=
# CONOR_STRAVA_CLIENT_SECRET=
# CONOR_STRAVA_REFRESH_TOKEN=
# CONOR_STRAVA_ACCESS_TOKEN=
# Optional single-athlete fallback keys:
# STRAVA_ATHLETE_ID=
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
# STRAVA_REFRESH_TOKEN=
# STRAVA_ACCESS_TOKEN=

# Strava sync trigger backend (optional)
# STRAVA_SYNC_WEBHOOK_URL=
# STRAVA_SYNC_WEBHOOK_TOKEN=
# STRAVA_SYNC_TRIGGER_MODE=internal
# STRAVA_SYNC_GITHUB_TOKEN=
# STRAVA_SYNC_GITHUB_OWNER=cmogle
# STRAVA_SYNC_GITHUB_REPO=strava-sync
# STRAVA_SYNC_GITHUB_WORKFLOW=fionnuala-manual-sync.yml
# STRAVA_SYNC_GITHUB_REF=main

# OpenAI coach (required for AI responses; fallback heuristics work without it)
# OPENAI_API_KEY=
# OPENAI_ORCHESTRATOR_MODEL=gpt-4.1
# OPENAI_MEMORY_MODEL=gpt-4.1-mini

# Service auth for daily check-in cron route
# CHECKIN_JOB_TOKEN=

# Feature flags (1/true/on to enable)
# FEATURE_MOBILE_SHELL_V2=true
# FEATURE_COACH_V1=true
# FEATURE_COACH_MEMORY_V1=true
# FEATURE_DAILY_CHECKIN_V1=true
# FEATURE_COACH_CONTEXT_V2=true
# FEATURE_COACH_BLOCKS_V2=true
# FEATURE_COACH_ROUTER_V1=true
# FEATURE_COACH_EVIDENCE_V1=true
# FEATURE_WELLNESS_SLEEP_V1=true
# FEATURE_WELLNESS_NUTRITION_V1=true

# One-time migration vars (legacy -> primary Supabase)
# SOURCE_SUPABASE_URL=
# SOURCE_SUPABASE_SERVICE_ROLE_KEY=
# TARGET_SUPABASE_URL=
# TARGET_SUPABASE_SERVICE_ROLE_KEY=
